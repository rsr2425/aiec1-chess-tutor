// Task 2 — Agent workflow: distillation graph + chat agent
digraph task2_agent_workflow {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, shape=box, style="rounded,filled", fillcolor="#f5f0e8", color="#8a7a5c"];
    edge [fontname="Helvetica", fontsize=9, color="#6b5d45"];

    upload [label="Student uploads annotated PGN", fillcolor="#e8eef5", color="#5c6f8a"];

    subgraph cluster_distill {
        label="Distillation graph (background run)";
        style="rounded"; color="#7a5c8a"; fontname="Helvetica";
        parse    [label="parse_pgn\nextract moves + student {comments}"];
        engpass  [label="engine_pass\nStockfish eval of every ply"];
        select   [label="select_moments\npure code: cp_loss ≥ 150, cap 6, floor 3,\nforce-include annotated ≥ 75"];
        describe [label="describe_moments\nLLM paragraph per moment"];
        distill  [label="distill\nLLM: takeaways + lesson ops\n(create / reinforce / merge / retire)"];
        index    [label="summarize_and_index\nLLM summary → embed → Qdrant"];
        parse -> engpass -> select -> describe -> distill -> index;
    }

    lessons [label="Lessons Store\n(cross-thread, per user)", shape=cylinder, fillcolor="#eee8f5", color="#7a5c8a"];
    qdrant  [label="Qdrant\nmoments · game_summaries · library", shape=cylinder, fillcolor="#e8f5ee", color="#5c8a6b"];

    subgraph cluster_chat {
        label="Chat agent (ReAct, per turn)";
        style="rounded"; color="#5c6f8a"; fontname="Helvetica";
        prompt [label="System prompt assembly\npersona + top-10 Lessons +\ngame summary + PGN"];
        llm    [label="LLM decides:\nanswer or call tool"];
        tools  [label="Tools\nanalyze_position (Stockfish)\nsearch_moments · search_games\nsearch_library · web_search"];
        reply  [label="Structured TutorReply\nreply text + positions[] (FEN chips)", fillcolor="#e8eef5"];
        prompt -> llm;
        llm -> tools [label="tool call"];
        tools -> llm [label="observation"];
        llm -> reply [label="final"];
    }

    student [label="Student chats;\nboard shows referenced positions", fillcolor="#e8eef5", color="#5c6f8a"];

    upload -> parse;
    distill -> lessons [label="write"];
    index -> qdrant [label="write"];
    lessons -> prompt [label="read top-10"];
    qdrant -> tools [label="retrieval"];
    reply -> student;
    student -> prompt [label="next question", style=dashed];
}
