# ── LLM Gateway (Vercel AI Gateway) ──────────────────────────────────────────
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=

# Models (Task 6: change DISTILL_MODEL to run before/after comparison)
CHAT_MODEL=openai/gpt-4.1-mini
DISTILL_MODEL=openai/gpt-4.1-mini
EMBED_MODEL=text-embedding-3-small

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Chess Engine Service ──────────────────────────────────────────────────────
ENGINE_SERVICE_URL=http://localhost:8001
ENGINE_SERVICE_TOKEN=
ENABLE_MAIA=true

# ── Web Search ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── LangSmith (tracing in all envs; hosting in prod) ─────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=chess-tutor-local

# ── LangGraph backend URL ─────────────────────────────────────────────────────
# Local Docker: http://backend:8000
# Production:   your LangSmith deployment URL
LANGGRAPH_API_URL=http://localhost:8000

# ── App branding (agent persona uses this) ────────────────────────────────────
APP_NAME=Blunderstanding
